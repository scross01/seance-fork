From a8ea4c69f96de0c3efc14c3001d5d2a383f95918 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Sipka=20D=C3=A1niel?= <sipka.daniel@leviathan.hu>
Date: Wed, 8 Apr 2026 15:44:12 +0200
Subject: [PATCH 5/7] Skip system library link on static lib steps to keep
 archives consumable

Zig 0.15 resolves `-l<name>` to the absolute path of the matching `.so`
when `linkSystemLibrary2` is called on a static library compile step,
embedding the resolved `.so` as a member of the resulting `.a`. ld.lld
then refuses to read the archive when a downstream consumer tries to
link it ("archive member '/lib64/libfoo.so' is neither ET_REL nor LLVM
bitcode"), and Zig promotes the LLD warning to a hard build error.

Add a `linkSystemLib` helper that no-ops on static lib steps and use it
for every system library reference reachable from a static lib build.
Module-level `linkSystemLibrary` calls also propagate into static
archives via the module DAG; drop the one in the fontconfig package
since the only consumer (SharedDeps.zig) already links fontconfig at
the compile-step level.
---
 pkg/fontconfig/build.zig |  5 ++++-
 src/build/SharedDeps.zig | 30 ++++++++++++++++++++++--------
 2 files changed, 26 insertions(+), 9 deletions(-)

diff --git a/pkg/fontconfig/build.zig b/pkg/fontconfig/build.zig
index 7c87d1f2e..14e7bfb63 100644
--- a/pkg/fontconfig/build.zig
+++ b/pkg/fontconfig/build.zig
@@ -40,7 +40,10 @@ pub fn build(b: *std.Build) !void {
     test_step.dependOn(&tests_run.step);
 
     if (b.systemIntegrationOption("fontconfig", .{})) {
-        module.linkSystemLibrary("fontconfig", dynamic_link_opts);
+        // Don't `module.linkSystemLibrary` here: it propagates to every
+        // Compile step that imports the module, including static libs,
+        // where Zig embeds the resolved `.so` as an archive member.
+        // Consumers must link fontconfig at the compile-step level.
         test_exe.linkSystemLibrary2("fontconfig", dynamic_link_opts);
     } else {
         const lib = try buildLib(b, module, .{
diff --git a/src/build/SharedDeps.zig b/src/build/SharedDeps.zig
index e5fd6cca4..0feef4f17 100644
--- a/src/build/SharedDeps.zig
+++ b/src/build/SharedDeps.zig
@@ -22,6 +22,19 @@ uucode_tables: std.Build.LazyPath,
 /// Used to keep track of a list of file sources.
 pub const LazyPathList = std.ArrayList(std.Build.LazyPath);
 
+/// `linkSystemLibrary2` that skips static-lib steps. On a static lib,
+/// Zig 0.15 resolves `-l<name>` to the matching `.so` and embeds it as
+/// an archive member, which ld.lld then refuses to read. Downstream
+/// consumers are responsible for linking the system library themselves.
+fn linkSystemLib(
+    step: *std.Build.Step.Compile,
+    name: []const u8,
+    options: std.Build.Module.LinkSystemLibraryOptions,
+) void {
+    if (step.isStaticLibrary()) return;
+    step.linkSystemLibrary2(name, options);
+}
+
 pub fn init(b: *std.Build, cfg: *const Config) !SharedDeps {
     const uucode_tables = blk: {
         const uucode = b.dependency("uucode", .{
@@ -149,8 +162,8 @@ pub fn add(
         );
 
         if (b.systemIntegrationOption("freetype", .{})) {
