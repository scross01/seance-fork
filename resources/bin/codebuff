#!/usr/bin/env bash
# seance Codebuff wrapper — intercepts `codebuff` invocations inside seance
# terminals and tracks the process lifecycle so seance can detect agent exit.
set -euo pipefail

# ── Find the real codebuff binary, skipping our own directory ────────────

WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REAL_CODEBUFF=""
IFS=: read -ra PATH_DIRS <<< "$PATH"
for dir in "${PATH_DIRS[@]}"; do
    [[ -z "$dir" ]] && continue
    resolved="$(cd "$dir" 2>/dev/null && pwd)" || continue
    [[ "$resolved" == "$WRAPPER_DIR" ]] && continue
    if [[ -x "$dir/codebuff" ]]; then
        REAL_CODEBUFF="$dir/codebuff"
        break
    fi
done

if [[ -z "$REAL_CODEBUFF" ]]; then
    echo "codebuff: command not found" >&2
    exit 127
fi

# Resolve seance to an absolute path
REAL_SEANCE="$(PATH="$PATH" type -P seance 2>/dev/null || true)"
if [[ -z "$REAL_SEANCE" ]]; then
    echo "codebuff: seance not found — falling back to pass-through" >&2
    exec "$REAL_CODEBUFF" "$@"
fi

# ── Pass-through conditions ──────────────────────────────────────────────

# Not inside seance
if [[ -z "${SEANCE_SURFACE_ID:-}" ]]; then
    exec "$REAL_CODEBUFF" "$@"
fi

# Hooks explicitly disabled
if [[ "${SEANCE_CODEBUFF_HOOKS_DISABLED:-}" == "1" ]]; then
    exec "$REAL_CODEBUFF" "$@"
fi

# Socket health check (0.75s timeout)
if ! timeout 0.75 "$REAL_SEANCE" ctl --socket "${SEANCE_SOCKET_PATH:-}" ping >/dev/null 2>&1; then
    exec "$REAL_CODEBUFF" "$@"
fi

# ── Export PID ─────────────────────────────────────────────────────────────

export SEANCE_CODEBUFF_PID=$$

# ── Session-end cleanup trap ───────────────────────────────────────────────

_STATUS_MONITOR_PID=""
_cleanup() {
    kill $_STATUS_MONITOR_PID 2>/dev/null || true
    timeout 0.5 "$REAL_SEANCE" ctl codebuff-hook session-end <<'EOF' >/dev/null 2>&1 &
{}
EOF
}
trap _cleanup EXIT

# ── Set initial "Running" status ───────────────────────────────────────────

"$REAL_SEANCE" ctl codebuff-hook prompt-submit <<'EOF' >/dev/null 2>&1 || true
{}
EOF

# ── Start background status monitor ────────────────────────────────────────
# Uses inotifywait on the manicode directory to detect session log writes.
# Requires inotify-tools package.
_start_status_monitor() {
    local manicode_dir="${HOME}/.config/manicode"

    (
        local idle_timeout=5
        local state_file
        state_file=$(mktemp /tmp/codebuff-status-XXXXXX)
        # Initialize to Running to match the initial prompt-submit status
        echo "Running" > "$state_file"

        while kill -0 $$ 2>/dev/null; do
            # Wait for IN_MODIFY events with timeout
            if timeout "$idle_timeout" inotifywait -r -q -e modify \
                --include '\.jsonl$' "$manicode_dir" >/dev/null 2>&1; then
                # Activity detected
                local current_status
                current_status=$(cat "$state_file" 2>/dev/null || echo "Idle")
                if [[ "$current_status" != "Running" ]]; then
                    echo "Running" > "$state_file"
                    timeout 0.5 "$REAL_SEANCE" ctl codebuff-hook prompt-submit <<'EOF' >/dev/null 2>&1 || true
{"status":"Running"}
EOF
                fi
            else
                # Timeout — no activity for idle_timeout seconds
                local current_status
                current_status=$(cat "$state_file" 2>/dev/null || echo "Idle")
                if [[ "$current_status" == "Running" ]]; then
                    echo "Idle" > "$state_file"
                    timeout 0.5 "$REAL_SEANCE" ctl codebuff-hook prompt-submit <<'EOF' >/dev/null 2>&1 || true
{"status":"Idle"}
EOF
                fi
            fi
        done
        rm -f "$state_file"
    ) &
    _STATUS_MONITOR_PID=$!
}
_start_status_monitor

# ── Launch codebuff (no exec — wrapper must survive for cleanup) ───────────

"$REAL_CODEBUFF" "$@"
rc=$?

exit $rc
