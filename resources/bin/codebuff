#!/usr/bin/env bash
# seance Codebuff wrapper — intercepts `codebuff` invocations inside seance
# terminals and tracks the process lifecycle so seance can detect agent exit.
set -euo pipefail

# ── Find the real codebuff binary, skipping our own directory ────────────

WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REAL_CODEBUFF=""
IFS=: read -ra PATH_DIRS <<< "$PATH"
for dir in "${PATH_DIRS[@]}"; do
    [[ -z "$dir" ]] && continue
    resolved="$(cd "$dir" 2>/dev/null && pwd)" || continue
    [[ "$resolved" == "$WRAPPER_DIR" ]] && continue
    if [[ -x "$dir/codebuff" ]]; then
        REAL_CODEBUFF="$dir/codebuff"
        break
    fi
done

if [[ -z "$REAL_CODEBUFF" ]]; then
    echo "codebuff: command not found" >&2
    exit 127
fi

# Resolve seance to an absolute path
REAL_SEANCE="$(PATH="$PATH" type -P seance 2>/dev/null || true)"
if [[ -z "$REAL_SEANCE" ]]; then
    echo "codebuff: seance not found — falling back to pass-through" >&2
    exec "$REAL_CODEBUFF" "$@"
fi

# ── Pass-through conditions ──────────────────────────────────────────────

# Not inside seance
if [[ -z "${SEANCE_SURFACE_ID:-}" ]]; then
    exec "$REAL_CODEBUFF" "$@"
fi

# Hooks explicitly disabled
if [[ "${SEANCE_CODEBUFF_HOOKS_DISABLED:-}" == "1" ]]; then
    exec "$REAL_CODEBUFF" "$@"
fi

# Socket health check (0.75s timeout)
if ! timeout 0.75 "$REAL_SEANCE" ctl --socket "${SEANCE_SOCKET_PATH:-}" ping >/dev/null 2>&1; then
    exec "$REAL_CODEBUFF" "$@"
fi

# ── Export PID ─────────────────────────────────────────────────────────────

export SEANCE_CODEBUFF_PID=$$

# ── Session-end cleanup trap ───────────────────────────────────────────────

_session_end_cleanup() {
    timeout 0.5 "$REAL_SEANCE" ctl codebuff-hook session-end <<'EOF' >/dev/null 2>&1 &
{}
EOF
}
trap _session_end_cleanup EXIT

# ── Set initial "Running" status ───────────────────────────────────────────

"$REAL_SEANCE" ctl codebuff-hook prompt-submit <<'EOF' >/dev/null 2>&1 || true
{}
EOF

# ── Launch codebuff (no exec — wrapper must survive for cleanup) ───────────

"$REAL_CODEBUFF" "$@"
rc=$?

exit $rc
