#!/usr/bin/env bash
# seance Kilo Code wrapper — intercepts `kilo` invocations inside seance
# terminals and tracks the process lifecycle so seance can detect agent exit.
set -euo pipefail

# ── Find the real kilo binary, skipping our own directory ─────────────────

WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REAL_KILO=""
IFS=: read -ra PATH_DIRS <<< "$PATH"
for dir in "${PATH_DIRS[@]}"; do
    [[ -z "$dir" ]] && continue
    resolved="$(cd "$dir" 2>/dev/null && pwd)" || continue
    [[ "$resolved" == "$WRAPPER_DIR" ]] && continue
    if [[ -x "$dir/kilo" ]]; then
        REAL_KILO="$dir/kilo"
        break
    fi
done

if [[ -z "$REAL_KILO" ]]; then
    echo "kilo: command not found" >&2
    exit 127
fi

# ── Pass-through conditions ──────────────────────────────────────────────

# Not inside seance
if [[ -z "${SEANCE_SURFACE_ID:-}" ]]; then
    exec "$REAL_KILO" "$@"
fi

# Hooks explicitly disabled
if [[ "${SEANCE_KILO_HOOKS_DISABLED:-}" == "1" ]]; then
    exec "$REAL_KILO" "$@"
fi

# Socket health check (0.75s timeout)
if ! timeout 0.75 seance ctl --socket "${SEANCE_SOCKET_PATH:-}" ping >/dev/null 2>&1; then
    exec "$REAL_KILO" "$@"
fi

# ── Export PID so seance can track this process ──────────────────────────

export SEANCE_KILO_PID=$$

# ── Launch kilo (no exec — wrapper must survive for cleanup) ─────────────

"$REAL_KILO" "$@"
rc=$?

# ── Session-end cleanup ──────────────────────────────────────────────────
# Kilo plugin may not fire session-end on crash or forced exit, so we
# always run it from the wrapper.

seance ctl kilo-hook session-end <<EOF 2>/dev/null || true
{"workspace_id":${SEANCE_WORKSPACE_ID:-null},"surface_id":${SEANCE_SURFACE_ID:-null}}
EOF

exit $rc
