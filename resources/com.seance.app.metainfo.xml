<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.seance.app</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Séance</name>
  <summary>Terminal multiplexer with AI agent support</summary>

  <description>
    <p>
      Séance is a GPU-accelerated terminal multiplexer built with GTK 4 and
      Ghostty. It provides tabbed workspaces, split panes, and first-class
      integration with AI coding agents like Claude Code and Codex.
    </p>
    <p>Features include:</p>
    <ul>
      <li>GPU-accelerated terminal rendering via Ghostty</li>
      <li>Tabbed workspaces with sidebar navigation</li>
      <li>Desktop notifications and progress tracking</li>
      <li>Configurable keybindings, fonts, and color themes</li>
      <li>Wayland and X11 transparency and blur support</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.seance.app.desktop</launchable>

  <url type="homepage">https://github.com/no1msd/seance</url>
  <url type="bugtracker">https://github.com/no1msd/seance/issues</url>
  <url type="vcs-browser">https://github.com/no1msd/seance</url>

  <developer id="com.seance">
    <name>Dániel Sipka</name>
  </developer>

  <provides>
    <binary>seance</binary>
  </provides>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.4" date="2026-05-01">
      <description>
        <p>Bug fixes and improvements.</p>
      </description>
    </release>
    <release version="0.1.0" date="2025-01-01">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>
</component>
